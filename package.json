{
  "name": "vynco",
  "version": "2.0.0",
  "description": "TypeScript SDK for the VynCo Swiss Corporate Intelligence API",
  "license": "Apache-2.0",
  "author": "VynCo <hello@vynco.ch>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "msw": "^2.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "vynco",
    "swiss",
    "company",
    "corporate-intelligence",
    "zefix",
    "sogc",
    "api",
    "sdk"
  ],
  "homepage": "https://vynco.ch",
  "repository": {
    "type": "git",
    "url": "https://github.com/VynCorp/vc-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/VynCorp/vc-typescript/issues"
  }
}
